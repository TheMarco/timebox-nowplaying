<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime resource-access entitlements (required once notarized). They're
         self-granted code-signing entitlements, not managed capabilities, so they don't need a
         provisioning profile. Network access and reading Claude Code's Keychain item need no
         entitlement for a non-sandboxed Developer ID app. -->
    <!-- Microphone capture for the optional Shazam now-playing source (SHManagedSession). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Send Apple events to Music.app for the System source's artwork fallback. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
