<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>TimeboxNowPlaying</string>
    <key>CFBundleIdentifier</key>
    <string>com.themarco.timebox-nowplaying</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Sends now-playing artwork and a clock to your Timebox display over Bluetooth.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Reads the current track's album artwork from Music to show it on your Timebox.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Listens to nearby music with Shazam to identify the song and show its cover on your display.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Finds and sends now-playing artwork and a clock to your Divoom Pixoo 64 over Wi-Fi.</string>
    <!-- The Pixoo's HTTP API is plain http on the local network; allow it (private/loopback
         addresses only) while keeping App Transport Security on for everything else. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
