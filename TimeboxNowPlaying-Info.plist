<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Claude Usage &amp; Now Playing for Pixoo 64</string>
    <key>CFBundleDisplayName</key>
    <string>Claude Usage &amp; Now Playing for Pixoo 64</string>
    <key>CFBundleExecutable</key>
    <string>ClaudeUsagePixoo64</string>
    <key>CFBundleIdentifier</key>
    <string>com.aicreated.pixoo64-claude</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHumanReadableCopyright</key>
    <string>Created by Marco van Hylckama Vlieg — ai-created.com</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Sends now-playing artwork and a clock to your Timebox display over Bluetooth.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Reads the current track's album artwork from Music to show it on your display.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Listens to nearby music with Shazam to identify the song and show its cover on your display.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Finds your Divoom Pixoo 64 on your Wi-Fi network to show Claude Code usage and now-playing art.</string>
    <!-- The Pixoo's HTTP API is plain http on the local network; allow it (private/loopback
         addresses only) while keeping App Transport Security on for everything else. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
